# Copy this file to `.env` and fill in the values.
# `.env` is gitignored and should never be committed.

# Required: secret used to sign/encrypt cookies, sessions, and tokens.
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Hostname the app is served from (used for URL generation).
# Use `localhost` for local dev, your real domain in production.
PHX_HOST=localhost
